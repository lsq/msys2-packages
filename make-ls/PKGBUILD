_realname=make-ls
pkgbase=mingw-w64-${_realname}
pkgname="${MINGW_PACKAGE_PREFIX}-${_realname}"
pkgdesc='Language Server for Makefile'
pkgver=0.1.16.r19.66ad9f7
pkgrel=1
arch=('any')
mingw_arch=('mingw32' 'mingw64' 'ucrt64' 'clang64' 'clangarm64')
url='https://github.com/owenrumney/make-ls.git'
# surl='https://github.com/lsq/libiconv.git'
surl='https://github.com/owenrumney/make-ls.git'
# surl='/c/Users/Administrator/github/libiconv'
license=('spdx:GPL-3.0-or-later')
makedepends=("${MINGW_PACKAGE_PREFIX}-cc"
             "${MINGW_PACKAGE_PREFIX}-autotools"
             "${MINGW_PACKAGE_PREFIX}-go")
source=("$_realname"::"git+${surl}"
        # fix-pointer-buf.patch
        )
sha256sums=('SKIP')
options=('!strip')

apply_patch_with_msg() {
  for _patch in "$@"
  do
    msg2 "Applying ${_patch}"
    patch -Nbp1 -i "${srcdir}/${_patch}"
  done
}

pkgver() {
    cd "${srcdir}/${_realname}"

    latest_version_published=$(git describe --tags --abbrev=0 | tail -1 | sed 's/^v//')
    # latest_commit_hash=$(git log -1 --format="%h")
    # echo "$latest_version_published.$latest_commit_hash"
    printf "%s.r%s.%s" $latest_version_published $(git rev-list --count HEAD) $(git rev-parse --short HEAD)
}

prepare() {
  cd "${srcdir}/${_realname}"

  sed -i '1s/\(BINARY := make-ls\)$/\1.exe/' Makefile
  head Makefile
  go env
  msg2 "运行 ..."

cat > new_pathFromURI.txt << 'EOF'
func pathFromURI(uri lsp.DocumentURI) string {
    s := string(uri)
    if strings.HasPrefix(s, "file://") {
        u, err := url.Parse(s)
        if err == nil {
            p := u.Path
            // Windows: file:///C:/foo 解析后 path=/C:/foo，去掉前导斜杠
            if len(p) >= 3 && p[0] == '/' && p[2] == ':' {
                p = p[1:]
            }
            return filepath.FromSlash(p)
        }
    }
    return s
}
EOF
cat > new_uriFromPath.txt << 'EOF'
func uriFromPath(path string) lsp.DocumentURI {
    p := filepath.ToSlash(path)
    // Windows: C:/foo → /C:/foo，确保生成 file:///C:/foo
    if len(p) >= 2 && p[1] == ':' {
        p = "/" + p
    }
    return lsp.DocumentURI((&url.URL{Scheme: "file", Path: p}).String())
}
EOF

# sed -i '/^func pathFromURI(uri lsp\.DocumentURI) string {$/,/^}$/c\
# PLACEHOLDER' main.go

# 上面的 c 命令对多行含特殊字符不友好，改用以下更可靠的方式：
sed -i -e '/^func pathFromURI(uri lsp\.DocumentURI) string {$/,/^}$/{' \
       -e '/^func pathFromURI(uri lsp\.DocumentURI) string {$/r new_pathFromURI.txt' \
       -e 'd' \
       -e '}' internal/resolver/resolver.go
sed -i -e '/^func uriFromPath(path string) lsp.DocumentURI {$/,/^}$/{' \
       -e '/^func uriFromPath(path string) lsp.DocumentURI {$/r new_uriFromPath.txt' \
       -e 'd' \
       -e '}' internal/resolver/resolver.go

}

build() {
  cd "${srcdir}/${_realname}"
  # mingw32-make STRIP=true
  # make install STRIP=true DESTDIR="$(pwd)"
  # mingw32-make build || msg2 "build failed"
  GOOS=windows GOARCH=amd64 go build -o bin/make-ls.exe ./cmd/make-ls
  if [ -f ./bin/make-ls.exe ];then
     mv ./bin/make-ls.exe .
  else
     msg2 "build failed"
  fi

  file ./${_realname}
}

package() {
  cd "${srcdir}/${_realname}"
  file ./${_realname}.exe
  MSYS2_ARG_CONV_EXCL="MINGW_PREFIX=" \
  install -D -m 755 --target-directory "${pkgdir}/${MINGW_PREFIX}/bin" ${_realname}
  file "${pkgdir}/${MINGW_PREFIX}/bin/${_realname}.exe"
  ls -R "${pkgdir}"
}

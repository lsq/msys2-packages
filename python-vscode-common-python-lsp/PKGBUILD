# Maintainer: Carl Smedstad <carsme@archlinux.org>

_realname=vscode-common-python-lsp
pkgbase=mingw-w64-python-${_realname}
pkgname=("${MINGW_PACKAGE_PREFIX}-python-${_realname}")
pkgver=0.6.0
pkgrel=1
pkgdesc="Common package for VSCode extensions exposing Python tools over LSP"
# mingw_arch=('mingw64' 'ucrt64' 'clang64' 'clangarm64')
mingw_arch=('ucrt64')
arch=(any)
url="https://github.com/microsoft/vscode-common-python-lsp"
msys2_repository_url='https://github.com/microsoft/vscode-common-python-lsp'
license=(MIT)
depends=(
  "${MINGW_PACKAGE_PREFIX}-python"
  "${MINGW_PACKAGE_PREFIX}-python-pygls"
  "${MINGW_PACKAGE_PREFIX}-python-lsprotocol"
  "${MINGW_PACKAGE_PREFIX}-python-packaging"
)
makedepends=(
  "${MINGW_PACKAGE_PREFIX}-python-build"
  "${MINGW_PACKAGE_PREFIX}-python-installer"
  "${MINGW_PACKAGE_PREFIX}-python-maturin"
  "${MINGW_PACKAGE_PREFIX}-python-wheel"
  "${MINGW_PACKAGE_PREFIX}-python-setuptools"
  "${MINGW_PACKAGE_PREFIX}-python-setuptools-rust"
  "${MINGW_PACKAGE_PREFIX}-python-pkgconfig"
  "${MINGW_PACKAGE_PREFIX}-cc"
  "git")
checkdepends=(
  # "${MINGW_PACKAGE_PREFIX}-python-dirty-equals"
  "${MINGW_PACKAGE_PREFIX}-python-pytest"
)
# source=("$_realname-$pkgver.tar.gz::$url/archive/v$pkgver.tar.gz")
source=("${_realname}-${pkgver}.tar.gz::${msys2_repository_url}/archive/refs/tags/v${pkgver}.tar.gz")
# source=("${_realname}"::"git+$url.git"
        # )
sha256sums=('646b84563dfd36f99ba4a4e391d9cdea3104a969fe88c89cdf09ae5f64fc9a5a')
# sha256sums=('aa9')

prepare() {
  if bsdtar -xf "${srcdir}/${_realname}-${pkgver}.tar.gz" 2>/dev/null ;then
    msg2 "${srcdir}/${_realname}-${pkgver} extracted successed!"
  else
    rm -rf ${srcdir}/${_realname}-${pkgver}
    export MSYS=winsymlinks:nativestrict
    tar xf "${srcdir}/${_realname}-${pkgver}.tar.gz" #|| bsdtar -xf "${srcdir}/${_realname}-${pkgver}.tar.gz"
  fi

  cd "${srcdir}/${_realname}-${pkgver}" && msg2 "Ending prepare ..."
  # patch -p1 -i "${srcdir}/001-mingw-setup.patch"
}

build() {
  # cd "${srcdir}/${_realname}"
  cp -r "${_realname}-${pkgver}"/python "python-build-${MSYSTEM}" && cd "python-build-${MSYSTEM}"
  cp "${srcdir}/${_realname}-${pkgver}"/LICENSE ./

  msg2 "$PATH"
  ${MINGW_PREFIX}/bin/python -m build --wheel --skip-dependency-check --no-isolation
  find . -name "*.whl"
}

package() {
  cd "${srcdir}/python-build-${MSYSTEM}"
  MSYS2_ARG_CONV_EXCL="--prefix=" \
    ${MINGW_PREFIX}/bin/python -m installer --prefix=${MINGW_PREFIX} \
    --destdir="$pkgdir" dist/*.whl
  install -vDm644 -t "$pkgdir${MINGW_PREFIX}/share/licenses/python-${_realname}" LICENSE
}

